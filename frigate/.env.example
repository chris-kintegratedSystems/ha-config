# Frigate environment variables
# Copy this to .env and fill in real values (never commit .env)

# Vivint doorbell RTSP (from Vivint panel at 192.168.51.106)
FRIGATE_VIVINT_RTSP_USER=user
FRIGATE_VIVINT_RTSP_PASS=changeme

# Google Nest SDM API credentials (from HA application_credentials)
FRIGATE_NEST_CLIENT_ID=changeme.apps.googleusercontent.com
FRIGATE_NEST_CLIENT_SECRET=GOCSPX-changeme
FRIGATE_NEST_REFRESH_TOKEN=1//changeme
FRIGATE_NEST_PROJECT_ID=changeme-uuid

# Nest camera device IDs (from HA entity registry unique_id, strip -camera suffix)
FRIGATE_NEST_CAM1_DEVICE_ID=AVPHwE-changeme
FRIGATE_NEST_CAM2_DEVICE_ID=AVPHwE-changeme

# Nanit baby UIDs (from nanit container logs / secrets.yaml)
FRIGATE_NANIT_BENJAMIN_UID=changeme
FRIGATE_NANIT_TRAVEL_UID=changeme
