# Home Assistant secrets — example template
#
# This file is COMMITTED to git as documentation only. The real
# secrets.yaml is gitignored and lives at
# /home/cooper5389/homeassistant/config/secrets.yaml on the Pi.
#
# When adding a new !secret reference in configuration.yaml (or any
# other YAML), add the key here with a placeholder value so future
# maintainers know what needs to exist in the live secrets file.

# ─── Nanit baby monitor RTMP streams ────────────────────────────────
# Full RTMP URL published by the seangreenhalgh/nanit container on the
# Pi. Baby UID is printed to the container log after first auth:
#   docker logs nanit | grep -i 'baby_uid'
# The UID does not change for a given camera.
# Replace REPLACE_WITH_BABY_UID with the value from the log.
nanit_benjamin_rtmp: "rtmp://192.168.51.179:1935/local/REPLACE_WITH_BABY_UID"
nanit_travel_rtmp: "rtmp://192.168.51.179:1935/local/REPLACE_WITH_BABY_UID"
